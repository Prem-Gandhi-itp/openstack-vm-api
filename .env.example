# Copy this file to .env and adjust values for your environment
# cp .env.example .env

# ── API Settings ──────────────────────────────────────────────────────────────
PROJECT_NAME="OpenStack VM Lifecycle API"
VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Security ──────────────────────────────────────────────────────────────────
# In production use a secrets manager (AWS Secrets Manager, Vault, etc.)
SECRET_KEY=change-me-in-production
VALID_API_KEYS=["dev-api-key-12345","another-key-here"]

# ── Mock vs Real OpenStack ────────────────────────────────────────────────────
# Set to false and configure OS_* vars below to connect to a real cluster
MOCK_OPENSTACK=true

# ── OpenStack Credentials (only used when MOCK_OPENSTACK=false) ───────────────
OS_AUTH_URL=http://keystone.example.com:5000/v3
OS_USERNAME=admin
OS_PASSWORD=your-openstack-password
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── Redis (optional, for production rate limiting) ────────────────────────────
# REDIS_URL=redis://localhost:6379/0
